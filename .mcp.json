{
  "name": "string-utils-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "slugify",
      "description": "Convert text to a URL-friendly slug.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "separator": {
            "type": "string"
          },
          "max_length": {
            "type": "integer"
          },
          "lowercase": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "camel_to_snake",
      "description": "Convert between camelCase, snake_case, kebab-case, and PascalCase.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "truncate_smart",
      "description": "Smartly truncate text at word boundaries with a suffix.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "max_length": {
            "type": "integer"
          },
          "suffix": {
            "type": "string"
          },
          "preserve_words": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "extract_numbers",
      "description": "Extract all numbers from text.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "include_decimals": {
            "type": "boolean"
          },
          "include_negative": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    }
  ]
}